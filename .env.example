MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/?appName=fakex
MONGODB_DB_NAME=fakex
# Public site URL for Open Graph / metadata (e.g. https://trollfarm.example.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
JWT_SECRET=your-long-random-secret
OPENAI_API_KEY=sk-your-openai-key
# Text model for profile bios and simulation posts/replies (default: gpt-4.1-nano)
OPENAI_TEXT_MODEL=gpt-4.1-nano
# Model for trending topic web search (default: gpt-4.1-mini)
OPENAI_TRENDING_MODEL=gpt-4.1-mini
# Model for pre-post topic research web search (default: OPENAI_TRENDING_MODEL)
# OPENAI_RESEARCH_MODEL=gpt-4.1-mini
# Required for avatars. Enable gpt-image-1 or gpt-image-2 on your OpenAI project first.
OPENAI_IMAGE_MODEL=gpt-image-1
# Simulation cron auth secret (required in production)
CRON_SECRET=your-random-secret
# Comma-separated admin usernames (case-insensitive)
ADMIN_USERNAMES=your-admin-username
# Simulation tick cadence, personality sampling, and engagement rates are configured in
# config/simulation.ts (not environment variables).
# Vercel cron for /api/cron/simulation runs every 15 minutes; keep tick.intervalMs at
# 900000 or lower so each cron invocation can run a tick.
# Optional: set to true only for local dev without OpenAI image access
# OPENAI_AVATAR_PROCEDURAL_FALLBACK=true
# Force rank NPC avatars to regenerate with celebrity-inspired pixel art
# RANK_NPC_REGENERATE_AVATARS=true
# Parallel avatar generation jobs during seed (default: 3)
# RANK_NPC_AVATAR_CONCURRENCY=3
# Parallel mirrored post pixel-art jobs (default: 2)
# RANK_NPC_POST_MEDIA_CONCURRENCY=2
# X API bearer token for rank NPC tweet mirroring (https://developer.x.com/)
# Paste the token exactly as shown in the developer portal. Quote the value if needed.
X_API_BEARER_TOKEN=your-x-api-bearer-token
# Delay between X API sync requests in milliseconds (default: 500)
# X_SYNC_DELAY_MS=500
# Rank NPC seed cooldown in milliseconds (default: 86400000 = 24 hours)
# RANK_NPC_SEED_WINDOW_MS=86400000
# Set to true only for local dev to bypass the once-per-day seed limit
# RANK_NPC_SEED_BYPASS_COOLDOWN=true
# Bootstrap seed: number of starter users (default: 7)
# BOOTSTRAP_PLAYER_COUNT=7
# Bootstrap seed: shared password for generated bootstrap users (default: bootstrap123)
# BOOTSTRAP_PLAYER_PASSWORD=bootstrap123
# Bootstrap seed: parallel bio/avatar generation jobs (default: 3)
# BOOTSTRAP_ASSET_CONCURRENCY=3
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..4Cv0beX9Pw1i2Z1aNUTVDq1u89ox3-9gGHkfKqr_0-w
# Optional dedicated gateway hostname. URLs stored in the DB use the public
# gateway by default so avatars load without extra access rules.
# PINATA_GATEWAY=your-subdomain.mypinata.cloud
# PINATA_USE_DEDICATED_GATEWAY=true
# NFT minting on Base (MetaMask + OpenSea)
# Base mainnet: 8453 | Base Sepolia testnet: 84532
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
# Set after deploy (npm run deploy:nft:mainnet or deploy:nft:sepolia)
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NFT_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
# 1000 = 10% secondary-sale royalty (ERC-2981)
NFT_ROYALTY_BPS=1000
# ~$1 at typical ETH prices (0.0006 ETH)
NFT_MINT_FEE_WEI=600000000000000
ALCHEMY_NOTIFY_SIGNING_KEY=your-alchemy-webhook-signing-key
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Optional: verify contract on Basescan after deploy (Etherscan API V2 key from
# https://etherscan.io/myapikey — not a legacy basescan.org-only key)
# BASESCAN_API_KEY=your-etherscan-v2-api-key
# Deployer wallet private key (never commit a real key)
# PRIVATE_KEY=0x...
